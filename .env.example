# ============================================================
# FreightClaims v5 — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── General ──────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ─────────────────────────────────────────────────
# Local: docker compose up -d postgres
# Prod:  AWS RDS connection string
DATABASE_URL=postgresql://freightclaims:freightclaims@localhost:5432/freightclaims

# ── JWT Authentication ───────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-char-secret-here
JWT_REFRESH_SECRET=your-64-char-refresh-secret-here
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── AWS S3 (Document Storage) ───────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=freightclaims-documents

# ── AWS SES (Email) ─────────────────────────────────────────
AWS_SES_FROM_EMAIL=noreply@freightclaims.com
AWS_SES_REPLY_TO=support@freightclaims.com

# ── Google Gemini (AI) ──────────────────────────────────────
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── AI Agent Service ────────────────────────────────────────
AI_AGENT_URL=http://localhost:8000

# ── Frontend (set in apps/web/.env.local) ────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Optional Services ───────────────────────────────────────
# SENDGRID_API_KEY=          # If using SendGrid for inbound parsing
# REDIS_URL=                 # If using Redis for caching/sessions
# GOOGLE_MAPS_API_KEY=       # For address autocomplete
# SENTRY_DSN=                # For error tracking
