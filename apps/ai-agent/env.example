# FreightClaims AI Agent - Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

# --- API Key for internal service-to-service auth ---
SERVICE_API_KEY=your-service-api-key

# --- Google Gemini ---
GEMINI_API_KEY=your-gemini-api-key
AI_MODEL=gemini-2.0-flash

# --- Encryption (for carrier portal credentials) ---
AI_AGENT_AES_KEY=your-32-char-aes-key

# --- AWS ---
AWS_REGION=us-east-2
AWS_S3_BUCKET_AI_PROMPTS=freightclaims-aibot
AWS_S3_BUCKET_DOCUMENTS=freightclaims-documents

# --- Timeouts ---
TIMEOUT_MS=120000

# --- Browser args (headless Chrome flags) ---
BROWSER_ARGS=--no-sandbox --disable-dev-shm-usage --disable-gpu --disable-extensions
