# ============================================================
# FreightClaims v5.0 - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# ============================================================

# --- General ---
NODE_ENV=development                     # development | staging | production
PORT=4000                                # API server port
WEB_PORT=3000                            # Next.js frontend port
AI_PORT=4100                             # AI agent server port

# --- Database (Render PostgreSQL / any Postgres) ---
DATABASE_URL=postgresql://freightclaims:localdev123@localhost:5432/freightclaims?sslmode=prefer
DATABASE_POOL_MIN=2                      # Minimum connection pool size
DATABASE_POOL_MAX=10                     # Maximum connection pool size

# --- Authentication ---
JWT_SECRET=your-jwt-secret-here          # Signing key for JWT tokens (min 32 chars)
JWT_EXPIRES_IN=24h                       # Token expiration duration
REFRESH_TOKEN_EXPIRES_IN=7d              # Refresh token lifespan

# --- Encryption ---
ENCRYPTION_KEY=your-32-char-encryption-key  # AES-256 encryption key for sensitive data

# --- File Storage ---
STORAGE_MODE=local                       # local | s3 (local stores files on disk, s3 requires AWS credentials)
LOCAL_UPLOAD_DIR=./uploads               # Directory for local file storage (when STORAGE_MODE=local)

# --- AWS (optional — only needed when STORAGE_MODE=s3) ---
AWS_REGION=us-east-2                     # AWS region
AWS_ACCESS_KEY_ID=                       # IAM access key (leave empty to skip AWS)
AWS_SECRET_ACCESS_KEY=                   # IAM secret key (leave empty to skip AWS)
S3_DOCUMENTS_BUCKET=freightclaims-documents  # S3 bucket for claim documents
S3_PROMPTS_BUCKET=freightclaims-aibot    # S3 bucket for AI prompt templates

# --- Email (SMTP — works with any provider: SendGrid, Mailgun, SES, etc.) ---
EMAIL_FROM=noreply@freightclaims.com     # Default sender address
SMTP_HOST=smtp.example.com              # SMTP server (use localhost:1025 for Mailpit in dev)
SMTP_PORT=587                            # SMTP port
SMTP_USER=your-smtp-user                 # SMTP username
SMTP_PASSWORD=your-smtp-password         # SMTP password

# --- AI / LLM (Google Gemini) ---
GEMINI_API_KEY=your-gemini-api-key       # Google Gemini API key for AI agents (leave empty to disable AI)
AI_MODEL=gemini-2.0-flash                # Default LLM model identifier

# --- External APIs ---
GOOGLE_MAPS_API_KEY=your-maps-key        # Google Maps / Places API key
SMARTY_KEY=your-smarty-key               # SmartyStreets address validation
CONVERT_API_SECRET=your-convert-key      # ConvertAPI for PDF processing
AMPLITUDE_API_KEY=your-amplitude-key     # Amplitude analytics

# --- URLs (production overrides) ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1   # Backend API base URL
NEXT_PUBLIC_AI_URL=http://localhost:4100/api/v1    # AI agent API base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000           # Frontend app URL

# --- Redis (optional, for caching — Render Redis or any Redis URL) ---
REDIS_URL=redis://localhost:6379         # Redis connection string

# --- Database Mode ---
DB_MODE=readwrite                        # readwrite | readonly (use readonly when connected to production DB as dev server)

# --- Logging ---
LOG_LEVEL=debug                          # error | warn | info | debug
LOG_FORMAT=pretty                        # json | pretty (use pretty for local dev, json for production)
