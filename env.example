# ============================================================
# FreightClaims v5.0 - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# ============================================================

# --- General ---
NODE_ENV=development                     # development | staging | production
PORT=4000                                # API server port

# --- Database (Render PostgreSQL / any Postgres) ---
DATABASE_URL=postgresql://freightclaims:localdev123@localhost:5432/freightclaims?sslmode=prefer
DATABASE_POOL_MIN=2                      # Minimum connection pool size
DATABASE_POOL_MAX=10                     # Maximum connection pool size

# --- Authentication ---
JWT_SECRET=your-jwt-secret-here          # Signing key for JWT tokens (min 32 chars)
JWT_EXPIRES_IN=24h                       # Token expiration duration
REFRESH_TOKEN_EXPIRES_IN=7d              # Refresh token lifespan

# --- Encryption ---
ENCRYPTION_KEY=your-32-char-encryption-key  # AES-256 encryption key for sensitive data

# --- File Storage ---
STORAGE_MODE=local                       # local | s3 (local stores files on disk, s3 requires AWS)
LOCAL_UPLOAD_DIR=./uploads               # Directory for local file storage

# --- AWS (optional — only needed when STORAGE_MODE=s3) ---
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_DOCUMENTS_BUCKET=freightclaims-documents
S3_PROMPTS_BUCKET=freightclaims-aibot

# --- Email (SendGrid SMTP) ---
EMAIL_FROM=claims@freightclaims.com      # Default sender address
SMTP_HOST=smtp.sendgrid.net             # SendGrid SMTP server
SMTP_PORT=587                            # SMTP port (587 for TLS, 465 for SSL)
SMTP_USER=apikey                         # SendGrid always uses "apikey" as the username
SMTP_PASSWORD=SG.your-sendgrid-api-key   # Your SendGrid API key (starts with SG.)

# --- ConvertAPI (document conversion) ---
CONVERT_API_SECRET=                      # ConvertAPI secret key (from account settings)

# --- AI / LLM (Google Gemini) ---
GEMINI_API_KEY=                          # Google Gemini API key (from aistudio.google.com)
AI_MODEL=gemini-2.0-flash               # Default LLM model

# --- External APIs (optional) ---
GOOGLE_MAPS_API_KEY=
SMARTY_KEY=
AMPLITUDE_API_KEY=

# --- URLs ---
NEXT_PUBLIC_API_URL=/api/v1              # API base URL for browser (relative path in production)
INTERNAL_API_HOST=localhost:4000         # Internal API host for Next.js rewrites
NEXT_PUBLIC_APP_URL=http://localhost:3000 # Frontend app URL (used for CORS)

# --- Redis (Render Redis or any Redis URL) ---
REDIS_URL=redis://localhost:6379

# --- Database Mode ---
DB_MODE=readwrite                        # readwrite | readonly

# --- Logging ---
LOG_LEVEL=debug                          # error | warn | info | debug
LOG_FORMAT=pretty                        # json | pretty (use json in production)
