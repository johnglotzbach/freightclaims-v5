// ============================================================
// FreightClaims v5.0 - Database Schema (Enterprise Overhaul)
// ============================================================
// Full PostgreSQL schema for the freight claims management platform.
// Covers: users, customers, claims, shipments, carriers, documents,
// email/notifications, AI agents, automation, workflows, and analytics.
//
// Location: packages/database/prisma/schema.prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS & AUTHENTICATION
// ============================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  phone         String?
  roleId        String?   @map("role_id")
  corporateId   String?   @map("corporate_id")
  customerId    String?   @map("customer_id")
  isActive              Boolean   @default(true) @map("is_active")
  isSuperAdmin          Boolean   @default(false) @map("is_super_admin")
  lastLoginAt           DateTime? @map("last_login_at")
  resetToken            String?   @map("reset_token")
  resetTokenExpiresAt   DateTime? @map("reset_token_expires_at")
  failedLoginAttempts   Int       @default(0) @map("failed_login_attempts")
  lockedUntil           DateTime? @map("locked_until")
  twoFactorSecret       String?   @map("two_factor_secret")
  twoFactorEnabled      Boolean   @default(false) @map("two_factor_enabled")
  emailVerified         Boolean   @default(false) @map("email_verified")
  verificationToken     String?   @map("verification_token")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  role          Role?              @relation(fields: [roleId], references: [id])
  customer      Customer?          @relation(fields: [customerId], references: [id])
  corporate     Customer?          @relation("CorporateUsers", fields: [corporateId], references: [id])
  preferences   UserPreference?
  claims           Claim[]            @relation("CreatedBy")
  claimsAssigned   Claim[]            @relation("ClaimAssignee")
  comments         ClaimComment[]
  tasksCreated     ClaimTask[]        @relation("TaskCreator")
  tasksAssigned    ClaimTask[]        @relation("TaskAssignee")
  timelineChanges  ClaimTimeline[]    @relation("TimelineChanges")
  conversations    AiConversation[]
  notifications    Notification[]
  notificationPreferences NotificationPreference[]
  activityLogs     ActivityLog[]
  apiKeys          ApiKey[]
  refreshTokens    RefreshToken[]
  savedDashboards  SavedDashboard[]

  @@index([corporateId])
  @@index([email])
  @@map("users")
}

model UserPreference {
  id                    String  @id @default(uuid())
  userId                String  @unique @map("user_id")
  emailNotifications    Boolean @default(true) @map("email_notifications")
  pushNotifications     Boolean @default(true) @map("push_notifications")
  dailyDigest           Boolean @default(false) @map("daily_digest")
  theme                 String  @default("light")
  timezone              String  @default("America/New_York")

  user User @relation(fields: [userId], references: [id])

  @@map("user_preferences")
}

model Role {
  id            String   @id @default(uuid())
  name          String
  description   String?
  corporateId   String?  @map("corporate_id")
  allClaims     Boolean  @default(false) @map("all_claims")
  allPermissions Boolean @default(false) @map("all_permissions")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       User[]

  @@unique([name, corporateId])
  @@index([corporateId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  module      String
  category    String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId       String  @map("role_id")
  permissionId String  @map("permission_id")
  isView       Boolean @default(true) @map("is_view")
  isEdit       Boolean @default(false) @map("is_edit")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================
// CUSTOMERS & COMPANIES
// ============================================================

model Customer {
  id          String    @id @default(uuid())
  name        String
  code        String?   @unique
  email       String?
  phone       String?
  website     String?
  industry    String?
  corporateId String?   @map("corporate_id")
  parentId    String?   @map("parent_id")
  isCorporate Boolean   @default(false) @map("is_corporate")
  isActive    Boolean   @default(true) @map("is_active")
  planType    String?   @map("plan_type")
  maxUsers    Int       @default(1) @map("max_users")
  billingEmail String?  @map("billing_email")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  ownerId     String?   @map("owner_id")

  parent         Customer?          @relation("CustomerHierarchy", fields: [parentId], references: [id])
  children       Customer[]         @relation("CustomerHierarchy")
  users          User[]
  corporateUsers User[]             @relation("CorporateUsers")
  contacts       CustomerContact[]
  addresses      CustomerAddress[]
  notes          CustomerNote[]
  productCatalog ProductCatalog[]
  claims         Claim[]
  shipments      Shipment[]

  @@index([corporateId])
  @@index([parentId])
  @@map("customers")
}

model CustomerContact {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  firstName  String   @map("first_name")
  lastName   String   @map("last_name")
  email      String?
  phone      String?
  title      String?
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("customer_contacts")
}

model CustomerAddress {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  type       String   @default("billing")
  street1    String
  street2    String?
  city       String
  state      String
  zipCode    String   @map("zip_code")
  country    String   @default("US")
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("customer_addresses")
}

model CustomerNote {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  content    String
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("customer_notes")
}

model ProductCatalog {
  id          String   @id @default(uuid())
  customerId   String   @map("customer_id")
  name        String
  sku         String?
  description String?
  value       Decimal? @db.Decimal(12, 2)
  weight      Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("product_catalog")
}

model Country {
  id   String @id @default(uuid())
  name String
  code String @unique

  @@map("countries")
}

// ============================================================
// CLAIMS
// ============================================================

model Claim {
  id                 String    @id @default(uuid())
  claimNumber        String    @unique @map("claim_number")
  proNumber          String    @map("pro_number")
  status             String    @default("draft")
  claimType          String    @map("claim_type")
  claimAmount        Decimal   @map("claim_amount") @db.Decimal(12, 2)
  settledAmount      Decimal?  @map("settled_amount") @db.Decimal(12, 2)
  reserveAmount      Decimal?  @map("reserve_amount") @db.Decimal(12, 2)
  description        String?
  shipDate           DateTime? @map("ship_date")
  deliveryDate       DateTime? @map("delivery_date")
  filingDate         DateTime? @map("filing_date")
  acknowledgmentDate DateTime? @map("acknowledgment_date")
  parentClaimId      String?   @map("parent_claim_id")
  assignedToId       String?   @map("assigned_to_id")
  corporateId        String?   @map("corporate_id")
  customerId         String    @map("customer_id")
  createdById        String    @map("created_by_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  customer       Customer           @relation(fields: [customerId], references: [id])
  createdBy      User               @relation("CreatedBy", fields: [createdById], references: [id])
  assignedTo     User?              @relation("ClaimAssignee", fields: [assignedToId], references: [id])
  parentClaim    Claim?             @relation("ClaimHierarchy", fields: [parentClaimId], references: [id])
  childClaims    Claim[]            @relation("ClaimHierarchy")
  parties        ClaimParty[]
  products       ClaimProduct[]
  comments       ClaimComment[]
  documents      ClaimDocument[]
  timeline       ClaimTimeline[]
  tasks          ClaimTask[]
  payments       ClaimPayment[]
  identifiers    ClaimIdentifier[]
  emailLogs      EmailLog[]
  aiDocuments    AiDocument[]
  deadlines      ClaimDeadline[]
  fraudFlags     FraudFlag[]
  predictions    ClaimPrediction[]
  damageAnalyses DamageAnalysis[]

  @@index([corporateId])
  @@index([customerId])
  @@index([status])
  @@index([claimNumber])
  @@index([proNumber])
  @@index([createdAt])
  @@index([assignedToId])
  @@index([parentClaimId])
  @@map("claims")
}

model ClaimParty {
  id         String   @id @default(uuid())
  claimId    String   @map("claim_id")
  type       String   // claimant, carrier, payee, shipper, consignee, 3pl, insurance
  name       String
  email      String?
  phone      String?
  address    String?
  city       String?
  state      String?
  zipCode    String?  @map("zip_code")
  contactName        String?   @map("contact_name")
  scacCode           String?   @map("scac_code")
  filingStatus       String?   @default("unfiled") @map("filing_status")
  filedDate          DateTime? @map("filed_date")
  acknowledgedDate   DateTime? @map("acknowledged_date")
  carrierClaimNumber String?   @map("carrier_claim_number")
  carrierResponse    String?   @map("carrier_response")
  createdAt          DateTime  @default(now()) @map("created_at")

  claim    Claim          @relation(fields: [claimId], references: [id])
  payments ClaimPayment[]

  @@index([claimId])
  @@map("claim_parties")
}

model ClaimProduct {
  id           String   @id @default(uuid())
  claimId      String   @map("claim_id")
  description  String
  quantity     Int      @default(1)
  weight       Decimal? @db.Decimal(10, 2)
  value        Decimal? @db.Decimal(12, 2)
  claimAmount  Decimal? @map("claim_amount") @db.Decimal(12, 2)
  unitCost     Decimal? @map("unit_cost") @db.Decimal(12, 2)
  sku          String?
  poNumber     String?  @map("po_number")
  condition    String?
  damageType   String?  @map("damage_type")
  nmfcCode     String?  @map("nmfc_code")
  freightClass String?  @map("freight_class")

  claim Claim @relation(fields: [claimId], references: [id])

  @@index([claimId])
  @@map("claim_products")
}

model ClaimComment {
  id              String    @id @default(uuid())
  claimId         String    @map("claim_id")
  userId          String    @map("user_id")
  content         String
  contentHtml     String?   @map("content_html")
  type            String    @default("comment") // comment, note, system, email
  parentId        String?   @map("parent_id")
  mentionedUserIds String?  @map("mentioned_user_ids")
  isPinned        Boolean   @default(false) @map("is_pinned")
  isInternal      Boolean   @default(false) @map("is_internal")
  editedAt        DateTime? @map("edited_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  claim   Claim          @relation(fields: [claimId], references: [id])
  user    User           @relation(fields: [userId], references: [id])
  parent  ClaimComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies ClaimComment[] @relation("CommentReplies")

  @@index([claimId])
  @@index([parentId])
  @@map("claim_comments")
}

model ClaimDocument {
  id                 String   @id @default(uuid())
  claimId            String?  @map("claim_id")
  categoryId         String?  @map("category_id")
  documentName       String   @map("document_name")
  s3Key              String   @map("s3_key")
  s3Bucket           String?  @map("s3_bucket")
  fileSize           Int?     @map("file_size")
  mimeType           String?  @map("mime_type")
  uploadedBy         String   @map("uploaded_by")
  aiProcessingStatus String?  @map("ai_processing_status")
  thumbnailKey       String?  @map("thumbnail_key")
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")

  claim    Claim?            @relation(fields: [claimId], references: [id])
  category DocumentCategory? @relation(fields: [categoryId], references: [id])

  @@index([claimId])
  @@map("claim_documents")
}

model ClaimTimeline {
  id          String   @id @default(uuid())
  claimId     String   @map("claim_id")
  status      String
  description String?
  changedById String   @map("changed_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  claim     Claim @relation(fields: [claimId], references: [id])
  changedBy User  @relation("TimelineChanges", fields: [changedById], references: [id])

  @@index([claimId])
  @@map("claim_timeline")
}

model ClaimTask {
  id              String    @id @default(uuid())
  claimId         String    @map("claim_id")
  title           String
  description     String?
  status          String    @default("pending")
  priority        String    @default("medium")
  dueDate         DateTime? @map("due_date")
  assignedTo      String?   @map("assigned_to")
  createdById     String    @map("created_by_id")
  reminderMinutes Int?      @map("reminder_minutes")
  completedAt     DateTime? @map("completed_at")
  emailLogId      String?   @map("email_log_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  claim          Claim @relation(fields: [claimId], references: [id])
  createdBy      User  @relation("TaskCreator", fields: [createdById], references: [id])
  assignedToUser User? @relation("TaskAssignee", fields: [assignedTo], references: [id])

  @@index([assignedTo])
  @@index([status])
  @@index([dueDate])
  @@map("claim_tasks")
}

model ClaimPayment {
  id              String    @id @default(uuid())
  claimId         String    @map("claim_id")
  claimPartyId    String?   @map("claim_party_id")
  amount          Decimal   @db.Decimal(12, 2)
  transactionType String    @default("inbound_payment") @map("transaction_type")
  direction       String    @default("inbound")
  paymentStatus   String    @default("cleared") @map("payment_status")
  method          String?
  type            String?
  reference       String?
  checkNumber     String?   @map("check_number")
  glCode          String?   @map("gl_code")
  payeeName       String?   @map("payee_name")
  vendorName      String?   @map("vendor_name")
  vendorPhone     String?   @map("vendor_phone")
  notes           String?
  currency        String    @default("USD")
  expectedDate    DateTime? @map("expected_date")
  receivedAt      DateTime? @map("received_at")
  createdById     String?   @map("created_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  claim      Claim       @relation(fields: [claimId], references: [id])
  claimParty ClaimParty? @relation(fields: [claimPartyId], references: [id])

  @@index([claimId])
  @@index([claimPartyId])
  @@index([transactionType])
  @@map("claim_payments")
}

model ClaimIdentifier {
  id        String   @id @default(uuid())
  claimId   String   @map("claim_id")
  type      String
  value     String
  createdAt DateTime @default(now()) @map("created_at")

  claim Claim @relation(fields: [claimId], references: [id])

  @@index([claimId])
  @@map("claim_identifiers")
}

model ClaimSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String
  label String?

  @@map("claim_settings")
}

// ============================================================
// DOCUMENTS & CATEGORIES
// ============================================================

model DocumentCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  documents ClaimDocument[]
  mappings  DocumentCategoryMapping[]

  @@map("document_categories")
}

model DocumentCategoryMapping {
  id         String @id @default(uuid())
  categoryId String @map("category_id")
  claimType  String @map("claim_type")
  isRequired Boolean @default(false) @map("is_required")

  category DocumentCategory @relation(fields: [categoryId], references: [id])

  @@map("document_category_mappings")
}

// ============================================================
// SHIPMENTS
// ============================================================

model Shipment {
  id              String    @id @default(uuid())
  proNumber       String    @map("pro_number")
  bolNumber       String?   @map("bol_number")
  carrierId       String?   @map("carrier_id")
  customerId      String?   @map("customer_id")
  corporateId     String?   @map("corporate_id")
  shipDate        DateTime? @map("ship_date")
  deliveryDate    DateTime? @map("delivery_date")
  originCity      String?   @map("origin_city")
  originState     String?   @map("origin_state")
  destinationCity String?   @map("destination_city")
  destinationState String?  @map("destination_state")
  weight          Decimal?  @db.Decimal(10, 2)
  pieces          Int?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  carrier   Carrier?          @relation(fields: [carrierId], references: [id])
  customer  Customer?         @relation(fields: [customerId], references: [id])
  contacts  ShipmentContact[]

  @@index([proNumber])
  @@index([corporateId])
  @@map("shipments")
}

model ShipmentContact {
  id         String @id @default(uuid())
  shipmentId String @map("shipment_id")
  name       String
  email      String?
  phone      String?
  type       String

  shipment Shipment @relation(fields: [shipmentId], references: [id])

  @@index([shipmentId])
  @@map("shipment_contacts")
}

// ============================================================
// CARRIERS
// ============================================================

model Carrier {
  id              String   @id @default(uuid())
  name            String
  scacCode        String?  @unique @map("scac_code")
  dotNumber       String?  @map("dot_number")
  mcNumber        String?  @map("mc_number")
  email           String?
  phone           String?
  website         String?
  address         String?
  city            String?
  state           String?
  zipCode         String?  @map("zip_code")
  capacityType    String?  @map("capacity_type")
  isInternational Boolean  @default(false) @map("is_international")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  shipments    Shipment[]
  contacts     CarrierContact[]
  integrations CarrierIntegration[]

  @@map("carriers")
}

model CarrierContact {
  id        String @id @default(uuid())
  carrierId String @map("carrier_id")
  name      String
  email     String?
  phone     String?
  title     String?
  department String?
  address   String?
  city      String?
  state     String?
  zipCode   String? @map("zip_code")

  carrier Carrier @relation(fields: [carrierId], references: [id])

  @@index([carrierId])
  @@map("carrier_contacts")
}

model CarrierIntegration {
  id        String   @id @default(uuid())
  carrierId String   @map("carrier_id")
  type      String
  portalUrl String?  @map("portal_url")
  apiKey    String?  @map("api_key")
  username  String?
  password  String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  carrier Carrier @relation(fields: [carrierId], references: [id])

  @@index([carrierId])
  @@map("carrier_integrations")
}

// ============================================================
// INSURANCE & SUPPLIERS
// ============================================================

model Insurance {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  policyNumber String? @map("policy_number")
  createdAt DateTime @default(now()) @map("created_at")

  contacts InsuranceContact[]

  @@map("insurances")
}

model InsuranceContact {
  id          String @id @default(uuid())
  insuranceId String @map("insurance_id")
  name        String
  email       String?
  phone       String?

  insurance Insurance @relation(fields: [insuranceId], references: [id])

  @@map("insurance_contacts")
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")

  addresses SupplierAddress[]

  @@map("suppliers")
}

model SupplierAddress {
  id         String @id @default(uuid())
  supplierId String @map("supplier_id")
  street1    String
  street2    String?
  city       String
  state      String
  zipCode    String @map("zip_code")
  country    String @default("US")

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@map("supplier_addresses")
}

// ============================================================
// EMAIL & NOTIFICATIONS
// ============================================================

model EmailLog {
  id            String   @id @default(uuid())
  claimId       String?  @map("claim_id")
  from          String
  to            String
  cc            String?
  bcc           String?
  subject       String
  body          String?
  contentHtml   String?  @map("content_html")
  status        String   @default("sent") // sent, failed, bounced, delivered, opened
  direction     String   @default("outbound")
  messageId     String?  @map("message_id")
  inReplyTo     String?  @map("in_reply_to")
  threadId      String?  @map("thread_id")
  attachmentIds Json?    @map("attachment_ids")
  openCount     Int      @default(0) @map("open_count")
  createdAt     DateTime @default(now()) @map("created_at")

  claim Claim? @relation(fields: [claimId], references: [id])

  @@index([claimId])
  @@index([threadId])
  @@index([messageId])
  @@map("email_logs")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  title     String
  message   String
  type      String    @default("info")
  category  String?
  link      String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@map("notifications")
}

model NotificationPreference {
  id           String @id @default(uuid())
  userId       String @map("user_id")
  eventType    String @map("event_type")
  inAppSetting String @default("all_claims") @map("in_app_setting")
  emailSetting String @default("all_claims") @map("email_setting")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, eventType])
  @@map("notification_preferences")
}

model EmailTemplate {
  id          String   @id @default(uuid())
  name        String
  subject     String
  body        String
  type        String
  corporateId String?  @map("corporate_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([corporateId])
  @@map("email_templates")
}

model LetterTemplate {
  id        String   @id @default(uuid())
  name      String
  content   String
  type      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("letter_templates")
}

model EmailQueue {
  id        String    @id @default(uuid())
  to        String
  from      String    @default("claims@freightclaims.com")
  subject   String
  body      String
  claimId   String?   @map("claim_id")
  status    String    @default("pending")
  error     String?
  attempts  Int       @default(0)
